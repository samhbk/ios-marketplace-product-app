# Local environment template (documentation only)
#
# This iOS app does not load a .env file at runtime. Use these values as reference
# when configuring the Xcode scheme or local tooling.
#
# Copy: cp .env.example .env
# Do not commit .env — it is gitignored.

# REST API base URL (no trailing slash)
# Also settable via Xcode scheme: MARKETPLACE_API_BASE_URL
# Or UserDefaults key: marketplace.api.baseURL
MARKETPLACE_API_BASE_URL=http://127.0.0.1:8000

# Optional: demo credentials for your local backend (never use production passwords)
# DEMO_API_EMAIL=demo@example.com
# DEMO_API_PASSWORD=
